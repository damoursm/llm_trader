# ══════════════════════════════════════════════════════
#  LLM Trader — Environment Configuration
#  Copy this file to .env and fill in your values.
#  All keys map directly to config/settings.py fields.
# ══════════════════════════════════════════════════════

# ── Core AI ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model used for final BUY/SELL/HOLD/WATCH synthesis
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (higher quality)
ANALYST_MODEL=claude-haiku-4-5-20251001

# DeepSeek API — per-ticker sentiment scoring (cheaper bulk tasks); falls back to Haiku if empty
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ── News & Market Data ────────────────────────────────
# https://newsapi.org/ (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here
# https://www.alphavantage.co/ (free tier: 25 req/day) — also used by Earnings Calendar
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── FRED (Federal Reserve of St. Louis) ──────────────
# Macro regime context: yield curve, CPI, unemployment, credit spreads, M2
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
ENABLE_FRED=true

# ── Feature Flags ─────────────────────────────────────
# Set ENABLE_FETCH_DATA=false to block all yfinance calls and use the most recent cached prices
ENABLE_FETCH_DATA=true
# Set ENABLE_CHARTS=true to build Plotly charts and save HTML report to logs/
ENABLE_CHARTS=false

# ── Signal Methods ────────────────────────────────────
ENABLE_NEWS_SENTIMENT=true
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_INSIDER_TRADES=true
ENABLE_OPTIONS_FLOW=true
ENABLE_SEC_FILINGS=true

# ── Smart Money ───────────────────────────────────────
INSIDER_LOOKBACK_DAYS=90
# Max ticker groups shown in the smart money section (email + console)
SMART_MONEY_TOP_TICKERS=5

# Politicians to prioritise (empty string = include all)
TRACKED_POLITICIANS="Nancy Pelosi,Paul Pelosi,Austin Scott,Michael McCaul,Dan Crenshaw,Tommy Tuberville,Shelley Moore Capito,Josh Gottheimer,Ro Khanna,Brian Higgins"

# 13F superinvestors to track (CIKs resolved automatically from EDGAR)
TRACKED_INSTITUTIONS="Berkshire Hathaway,Pershing Square Capital Management,Appaloosa Management,Baupost Group"

# Lookback window for 13D/13G activist stakes and Form 144 planned sales
SEC_FILINGS_LOOKBACK_DAYS=30

# ── CFTC Commitment of Traders ────────────────────────
# Weekly futures positioning for commodities + index ETFs — no API key required
# Cached by ISO week; first run each week downloads ~10 MB from CFTC
ENABLE_COT=true

# ── SEC 8-K Material Event Filings ───────────────────
# Earnings announcements, M&A, leadership changes, restatements — no API key required
ENABLE_8K_FILINGS=true
EIGHT_K_LOOKBACK_DAYS=5

# ── SEC S-1/S-11 IPO Pipeline ────────────────────────
# Sector-level institutional demand signal from registration statements — no API key required
ENABLE_IPO_PIPELINE=true
IPO_LOOKBACK_DAYS=30

# ── VIX & Term Structure ──────────────────────────────
# ^VIX, ^VXN, ^VVIX, ^VIX9D, ^VIX3M, ^VXMT — all free via yfinance, no key required
# Contango vs backwardation gives regime context; extreme VIX = contrarian signal
ENABLE_VIX=true

# ── Put/Call Ratio ────────────────────────────────────
# Market-wide: CBOE equity P/C CSV (free, no key) — contrarian fear/greed indicator
# Per-ticker: yfinance options volume (free, no key) — directional positioning signal
ENABLE_PUT_CALL=true

# ── Analyst Ratings ──────────────────────────────────
# Upgrades, downgrades, initiations, and price-target changes — yfinance (free, no key)
# Surfaces any upgrade/downgrade, new bullish/bearish initiations, or ≥2 PT moves in same direction
ENABLE_ANALYST_RATINGS=true
ANALYST_RATINGS_LOOKBACK_DAYS=30

# ── Earnings Calendar + EPS Surprises ────────────────
# Primary source: yfinance (free, no key required)
# Alpha Vantage EARNINGS_CALENDAR supplements upcoming dates if ALPHA_VANTAGE_KEY is set above
ENABLE_EARNINGS=true
EARNINGS_LOOKBACK_DAYS=90
EARNINGS_UPCOMING_DAYS=14

# ── Short Interest ────────────────────────────────────
# FINRA Reg SHO daily short volume + yfinance bi-weekly snapshot — no key required
# Squeeze setups (SI > 15% + DTC 2-10), bearish build (SI up > 20% MoM),
# short covering (SI down > 20% MoM)
ENABLE_SHORT_INTEREST=true

# ── Google Trends ─────────────────────────────────────
# Search interest spike/drop as retail attention proxy — no API key required
# Uses pytrends (unofficial API); cached daily; throttled at 1.5s/batch
ENABLE_GOOGLE_TRENDS=true

# ── Reddit Social Sentiment ───────────────────────────
# Scans r/wallstreetbets, r/stocks, r/investing for ticker mentions (last 24h)
# Create a free "script" app at: https://www.reddit.com/prefs/apps
ENABLE_REDDIT_SENTIMENT=true
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT="llm_trader/1.0 (stock analysis bot)"

# ── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ── Scheduler ─────────────────────────────────────────
# Cron expression for the daily pre-market run (Mon-Fri, US/Eastern)
SCHEDULE_DAILY=0 8 * * 1-5

# ── Watchlist ─────────────────────────────────────────
STOCK_WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL
SECTOR_ETFS=XLK,XLF,XLE,XLV,XLY,XLP,XLI,XLB,XLU,XLRE,XLC
# GLD/IAU=Gold, SLV=Silver, GDX=Gold Miners, PPLT=Platinum, PALL=Palladium, CPER=Copper
COMMODITY_ETFS=GLD,SLV,IAU,GDX,PPLT,PALL,CPER
