# === Claude API ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === News Sources ===
NEWSAPI_KEY=your_newsapi_key_here          # https://newsapi.org/
ALPHA_VANTAGE_KEY=your_alpha_vantage_key   # https://www.alphavantage.co/

# === FRED (Federal Reserve — macro context) ===
FRED_API_KEY=your_fred_api_key_here        # https://fred.stlouisfed.org/docs/api/api_key.html (free)
ENABLE_FRED=true

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here       # Gmail app password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# === Scheduler ===
# Cron expressions for when to run analysis (market hours ET)
SCHEDULE_PREMARKET=0 8 * * 1-5             # 8:00 AM ET Mon-Fri
SCHEDULE_MIDDAY=0 12 * * 1-5              # 12:00 PM ET Mon-Fri
SCHEDULE_CLOSE=30 16 * * 1-5             # 4:30 PM ET Mon-Fri

# === Watchlist ===
# Comma-separated tickers and sectors to monitor
STOCK_WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL
SECTOR_ETFS=XLK,XLF,XLE,XLV,XLY,XLP,XLI,XLB,XLU,XLRE,XLC
