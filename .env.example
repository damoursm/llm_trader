# ══════════════════════════════════════════════════════
#  LLM Trader — Environment Configuration
#  Copy this file to .env and fill in your values.
#  All keys map directly to config/settings.py fields.
# ══════════════════════════════════════════════════════

# ── Core AI ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model used for final BUY/SELL/HOLD/WATCH synthesis
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (higher quality)
ANALYST_MODEL=claude-haiku-4-5-20251001

# DeepSeek API — per-ticker sentiment scoring (cheaper bulk tasks); falls back to Haiku if empty
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ── News & Market Data ────────────────────────────────
# https://newsapi.org/ (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here
# https://www.alphavantage.co/ (free tier: 25 req/day) — also used by Earnings Calendar
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── FRED (Federal Reserve of St. Louis) ──────────────
# Macro regime context: yield curve, CPI, unemployment, credit spreads, M2
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
ENABLE_FRED=true

# ── Feature Flags ─────────────────────────────────────
# Set ENABLE_FETCH_DATA=false to block all yfinance calls and use the most recent cached prices
ENABLE_FETCH_DATA=true
# Set ENABLE_CHARTS=true to build Plotly charts and save HTML report to logs/
ENABLE_CHARTS=false

# ── Signal Methods ────────────────────────────────────
ENABLE_NEWS_SENTIMENT=true
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_INSIDER_TRADES=true
ENABLE_OPTIONS_FLOW=true
ENABLE_SEC_FILINGS=true

# ── Smart Money ───────────────────────────────────────
INSIDER_LOOKBACK_DAYS=90
# Max ticker groups shown in the smart money section (email + console)
SMART_MONEY_TOP_TICKERS=5

# Politicians to prioritise (empty string = include all)
TRACKED_POLITICIANS="Nancy Pelosi,Paul Pelosi,Austin Scott,Michael McCaul,Dan Crenshaw,Tommy Tuberville,Shelley Moore Capito,Josh Gottheimer,Ro Khanna,Brian Higgins"

# 13F superinvestors to track (CIKs resolved automatically from EDGAR)
TRACKED_INSTITUTIONS="Berkshire Hathaway,Pershing Square Capital Management,Appaloosa Management,Baupost Group"

# Lookback window for 13D/13G activist stakes and Form 144 planned sales
SEC_FILINGS_LOOKBACK_DAYS=30

# ── CFTC Commitment of Traders ────────────────────────
# Weekly futures positioning for commodities + index ETFs — no API key required
# Cached by ISO week; first run each week downloads ~10 MB from CFTC
ENABLE_COT=true

# ── SEC 8-K Material Event Filings ───────────────────
# Earnings announcements, M&A, leadership changes, restatements — no API key required
ENABLE_8K_FILINGS=true
EIGHT_K_LOOKBACK_DAYS=5

# ── SEC S-1/S-11 IPO Pipeline ────────────────────────
# Sector-level institutional demand signal from registration statements — no API key required
ENABLE_IPO_PIPELINE=true
IPO_LOOKBACK_DAYS=30

# ── VIX & Term Structure ──────────────────────────────
# ^VIX, ^VXN, ^VVIX, ^VIX9D, ^VIX3M, ^VXMT — all free via yfinance, no key required
# Contango vs backwardation gives regime context; extreme VIX = contrarian signal
ENABLE_VIX=true

# ── Put/Call Ratio ────────────────────────────────────
# Market-wide: CBOE equity P/C CSV (free, no key) — contrarian fear/greed indicator
# Per-ticker: yfinance options volume (free, no key) — directional positioning signal
ENABLE_PUT_CALL=true

# ── Analyst Ratings ──────────────────────────────────
# Upgrades, downgrades, initiations, and price-target changes — yfinance (free, no key)
# Surfaces any upgrade/downgrade, new bullish/bearish initiations, or ≥2 PT moves in same direction
ENABLE_ANALYST_RATINGS=true
ANALYST_RATINGS_LOOKBACK_DAYS=30

# ── Earnings Calendar + EPS Surprises ────────────────
# Primary source: yfinance (free, no key required)
# Alpha Vantage EARNINGS_CALENDAR supplements upcoming dates if ALPHA_VANTAGE_KEY is set above
ENABLE_EARNINGS=true
EARNINGS_LOOKBACK_DAYS=90
EARNINGS_UPCOMING_DAYS=14

# ── Short Interest ────────────────────────────────────
# FINRA Reg SHO daily short volume + yfinance bi-weekly snapshot — no key required
# Squeeze setups (SI > 15% + DTC 2-10), bearish build (SI up > 20% MoM),
# short covering (SI down > 20% MoM)
ENABLE_SHORT_INTEREST=true

# ── Google Trends ─────────────────────────────────────
# Search interest spike/drop as retail attention proxy — no API key required
# Uses pytrends (unofficial API); cached daily; throttled at 1.5s/batch
ENABLE_GOOGLE_TRENDS=true

# ── Reddit Social Sentiment ───────────────────────────
# Scans r/wallstreetbets, r/stocks, r/investing for ticker mentions (last 24h)
# Create a free "script" app at: https://www.reddit.com/prefs/apps
ENABLE_REDDIT_SENTIMENT=true
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT="llm_trader/1.0 (stock analysis bot)"

# ── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ── Scheduler ─────────────────────────────────────────
# Cron expression for the daily pre-market run (Mon-Fri, US/Eastern)
SCHEDULE_DAILY=0 8 * * 1-5

# ── Watchlist ─────────────────────────────────────────
STOCK_WATCHLIST=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL
SECTOR_ETFS=XLK,XLF,XLE,XLV,XLY,XLP,XLI,XLB,XLU,XLRE,XLC
# GLD/IAU=Gold, SLV=Silver, GDX=Gold Miners, PPLT=Platinum, PALL=Palladium, CPER=Copper
COMMODITY_ETFS=GLD,SLV,IAU,GDX,PPLT,PALL,CPER

# ── Macro News Regime (geopolitics / oil / tariffs / policy) ─────
# Scans the day's news flow for macro-level themes (active wars and
# geopolitical escalation, trade/tariff actions, oil/energy shocks,
# central-bank surprises, fiscal/policy events, black swans) and produces
# a composite regime read (STABLE / WATCH / ELEVATED_RISK / CRISIS) with
# per-theme sector implications. The composite feeds the Macro Regime
# Filter (weight 1.5) so high-stress macro headlines actually tighten the
# BUY threshold — CRISIS can trigger PANIC by itself and block new longs.
# Classification: DeepSeek when DEEPSEEK_API_KEY is set, deterministic
# keyword-density heuristic otherwise. Cached hourly.
ENABLE_MACRO_NEWS=true
MACRO_NEWS_MAX_ARTICLES=60
MACRO_NEWS_MIN_ARTICLES=3

# ── Intermarket Divergence (broad indices vs SPY) ────────────────
# Cross-market regime detector: tracks IWM, RSP, QQQ, DIA, MDY, EFA, EEM,
# IWF, IWD relative to SPY over 1m / 3m windows. Surfaces canonical regime
# labels (NARROW_LEADERSHIP, BROAD_PARTICIPATION, GROWTH_ROTATION,
# VALUE_ROTATION, US_EXCEPTIONALISM, INTERNATIONAL_STRENGTH, MID_CAP_LEADERSHIP,
# CYCLICAL_LEAD). The composite intermarket_health feeds the Macro Regime
# Filter so narrow-leadership warnings actually tighten the BUY threshold,
# and is also passed to the Claude analyst as context.
ENABLE_INTERMARKET=true

# ── Correlation-Aware Position Sizing ────────────────────────────
# At trade-open time, compute realized pairwise correlations from the last
# N trading days of OHLCV closes between the new candidate and every OPEN
# same-direction position. A high mean correlation (lots of factor overlap
# with existing trades) shrinks the candidate's size linearly between the
# low/high thresholds. The portfolio cap is a hard skip: when the sum of
# Σ(other_size · |ρ|) over same-direction peers would exceed it, the trade
# is rejected entirely.
ENABLE_CORRELATION_SIZING=true
CORRELATION_LOOKBACK_DAYS=60
CORRELATION_LOW_THRESHOLD=0.30
CORRELATION_HIGH_THRESHOLD=0.80
CORRELATION_MIN_MULTIPLIER=0.25
CORRELATION_PORTFOLIO_CAP=2.5
CORRELATION_MIN_OVERLAP_DAYS=20

# ── Sector-Relative Momentum (beta-stripped alpha factor) ───────
# Strips out sector beta from the price-momentum signal: ticker minus sector
# ETF (XLK, XLF, …; SPY fallback for unmapped names). The cleaner alpha factor
# in factor literature — answers "did this name outperform peers?" rather
# than "did this name go up?". Benchmark mapping cached in cache/sector_benchmark_map.json.
ENABLE_SECTOR_RELATIVE_MOMENTUM=true

# ── Market-Relative Momentum (diagnostic vs SPY) ─────────────────
# Companion to sector-relative: ticker minus SPY. Shown alongside the
# sector-relative card so divergences are visible at a glance:
#   sector+ market+: ALPHA LEADER       sector+ market-: BEST OF A WEAK SECTOR
#   sector- market-: TRUE LAGGARD        sector- market+: STOCK-SPECIFIC DRAG
#   sector≈0 market-: BETA DRAG          sector≈0 market+: BETA TAILWIND
# NOT added to the weighted combo (would double-count beta given sector-rel
# already captures the stock-vs-sector slice). Pure diagnostic.
ENABLE_MARKET_RELATIVE_MOMENTUM=true

# ── Out-of-Sample Validation (deterministic train/holdout split) ─
# Each closed trade is permanently assigned to "train" or "holdout" via a
# deterministic hash of (seed, ticker, entry_date). Adaptive weights are fit
# on train only; holdout stats appear in the email as an honest OOS check.
# This is a fixed partition — NOT a walk-forward (no rolling re-training).
# Change OOS_SPLIT_SEED to ANY new string to reshuffle the partition.
# Set OOS_HOLDOUT_PCT=0 (or disable the flag) to turn the holdout off.
ENABLE_OOS_VALIDATION=true
OOS_HOLDOUT_PCT=30
OOS_SPLIT_SEED=llm_trader_v1

# ── Hypothetical Always-Open Book ────────────────────
# Reference baseline trades that are ALWAYS held in an open position.
# Format: "TICKER:ACTION,…" where ACTION is BUY or SELL (defaults to BUY).
# Legacy LONG/SHORT values are accepted and normalised to BUY/SELL.
# Stored in cache/hypothetical_trades.json and shown in their own email section.
# DO NOT contribute to real-trade performance metrics — fully isolated.
ENABLE_HYPOTHETICAL_TRADES=true
HYPOTHETICAL_TRADES=GLD:BUY,SLV:BUY,GDX:BUY,NVDA:BUY

# ── Broker / live execution (paper-first via Interactive Brokers) ────
# Drive a real broker's PAPER account in parallel with the internal NAV sim
# ("shadow & reconcile"), then flip to live with a port swap. OFF by default →
# no broker calls at all (behavior unchanged). IBKR is the only API broker that
# lets a Canadian resident paper AND live trade US securities; the CIRO API
# restriction applies only to Canadian-listed names, which this system never trades.
# Phased rollout: dry_run → ibkr_paper → (later) ibkr_live.
#   off | dry_run | ibkr_paper | ibkr_live
BROKER_MODE=off
# IB Gateway (or TWS) must be running with the API enabled. Ports:
#   IB Gateway: 4002 paper / 4001 live    TWS: 7497 paper / 7496 live
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=11
IBKR_ACCOUNT=
IBKR_CONNECT_TIMEOUT=15
# Sizing. notional mode (default): fixed base order size BROKER_BASE_NOTIONAL in
# BROKER_BASE_NOTIONAL_CCY x the 1.0/1.5/2.0x confidence tier. US stocks are USD-priced,
# so a CAD base is converted to a USD share budget via live FX (fallback below).
# equity_pct mode: BROKER_BASE_POSITION_PCT of account equity x the tier.
BROKER_SIZING_MODE=notional
BROKER_BASE_NOTIONAL=1000
BROKER_BASE_NOTIONAL_CCY=CAD
BROKER_FX_FALLBACK_CAD_USD=0.73
# IBKR's API can't place fractional equity orders (GUI-only), so small positions round to
# whole shares. "nearest" = round half-up (avoids skipping reasonably-priced names);
# "floor" = strict budget (skips any name priced above one position's worth).
BROKER_SHARE_ROUNDING=nearest
BROKER_BASE_POSITION_PCT=0.05
BROKER_MAX_POSITIONS=20
BROKER_MAX_GROSS_EXPOSURE_PCT=1.0
BROKER_ORDER_TYPE=MKT
# USD equity used for the exposure cap in dry_run
BROKER_PAPER_EQUITY=100000
